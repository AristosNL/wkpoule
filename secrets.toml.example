# Streamlit Secrets — voorbeeld
# ------------------------------
# Op de cloud: kopieer onderstaande regels (met je echte sleutels) naar het
#              Secrets-veld in je Streamlit Cloud-app-instellingen.
# Lokaal:      hernoem dit bestand naar 'secrets.toml' (zonder .example) en
#              vul je sleutels in. .gitignore zorgt dat het niet op GitHub komt.

ODDS_API_KEY = "jouw-the-odds-api-sleutel"
APIFOOTBALL_KEY = "jouw-api-football-sleutel"
